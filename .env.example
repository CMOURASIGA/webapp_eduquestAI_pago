# Backend (Express): chave usada pelos endpoints /api/openai/*
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Frontend (Gemini): chave usada pelo SDK do Gemini no navegador
API_KEY=gk-xxxxxxxxxxxxxxxx

# Nomes autorizados para usar a chave customizada digitada no painel
SPECIAL_STUDENT_NAME=LUCAS
SPECIAL_PROFESSOR_NAME=CHRISTIAN

# Controle de acesso/pagamentos
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
MIN_MANUAL_RELEASE_HOURS=1

# Se definido, ativa modo de pagamento real manual via PIX
PIX_PAYMENT_KEY=
PIX_PAYMENT_RECIPIENT=EduQuest IA

# Acesso gratuito inicial (uso unico por conta)
FREE_ONCE_PLAN_ID=FREE_ONCE
FREE_ONCE_CREDITS=40
FREE_ONCE_VALIDITY_DAYS=7
